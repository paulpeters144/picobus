<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
	<GeneratePackageOnBuild>True</GeneratePackageOnBuild>
	<Title>PicoBus</Title>
	<PackageReadmeFile>README.md</PackageReadmeFile>
	<PackageId>PicoBus</PackageId>
	<Version>0.0.6</Version>	<PackageLicenseExpression>MIT</PackageLicenseExpression>
	<Authors>Paul Q. Peters</Authors>
	<Product>PicoBus</Product>
	<Description>
		A lightweight, thread-safe, in-memory event bus for .NET. with zero dependencies.
	</Description>
	<PackageProjectUrl>https://github.com/paulpeters144/PicoBus</PackageProjectUrl>
	<PackageTags>Event; Bus; EventBus; Simple; Pico; PicoBus</PackageTags>
	<PackageIcon>icon.png</PackageIcon>
	<RepositoryUrl>https://github.com/paulpeters144/PicoBus</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
	  <None Include="..\icon.png">
		  <Pack>True</Pack>
		  <PackagePath>\</PackagePath>
	  </None>
	  <None Include="..\README.md">
		  <Pack>True</Pack>
		  <PackagePath>\</PackagePath>
	  </None>
  </ItemGroup>
</Project>
